<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>TuneHub | Music Management System</title>
  <link rel="stylesheet" href="CSS/home.css" />
</head>
<body>

<!-- HERO SECTION -->
<section class="hero">
  <div class="hero-container">


    <h1 class="hero-title">
      Your music. <br />
      <span class="highlight">Perfectly tuned.</span>
    </h1>

    <p class="hero-subtitle">
      TuneUp is a simple, intuitive space to log your music library,
      organize tracks by genre, and manage your entire collection in one place.
    </p>

    <div class="hero-actions">
      <a href="LoginController" class="btn primary">
        Get Started →
      </a>
    </div>

  </div>
</section>

<!-- FEATURES -->
<section class="features">
  <div class="features-container">

    <div class="features-header">
      <h2>Master Your Library</h2>
      <p>Everything you need to keep your digital record spinning.</p>
    </div>

    <div class="features-grid">

      <div class="feature-card">
        <div class="icon">➕</div>
        <h3>Build Your Collection</h3>
        <p>Easily log your favorite songs with titles, artists, and albums.</p>
      </div>

      <div class="feature-card">
        <div class="icon">📂</div>
        <h3>Organize by Genre</h3>
        <p>Categorize your music across various genres easily.</p>
      </div>

      <div class="feature-card">
        <div class="icon">📀</div>
        <h3>Track Your Library</h3>
        <p>Keep records of duration, dates, and track details.</p>
      </div>

      <div class="feature-card">
        <div class="icon">🔍</div>
        <h3>Rediscover Music</h3>
        <p>Find your old favorites anytime in your collection.</p>
      </div>

    </div>

  </div>
</section>

</body>
</html>